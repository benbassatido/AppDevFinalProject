<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.App.LoginTextInputLayout"
        parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <item name="boxBackgroundColor">@color/login_field_bg</item>

        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>

        <item name="boxStrokeColor">@color/login_stroke_selector</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>

        <item name="hintTextColor">@color/login_hint_selector</item>
    </style>

    <style name="DarkConfirmDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>

        <item name="android:background">@drawable/bg_dark_dialog</item>

        <item name="materialAlertDialogBodyTextStyle">@style/DarkDialogBody</item>
        <item name="shapeAppearanceOverlay">@style/DarkDialogShape</item>

        <item name="buttonBarPositiveButtonStyle">@style/DarkDialogPositive</item>
        <item name="buttonBarNegativeButtonStyle">@style/DarkDialogNegative</item>
    </style>


    <style name="DarkDialogBody" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="DarkDialogShape">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="DarkDialogPositive" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#F87171</item>
    </style>

    <style name="DarkDialogNegative" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#9CA3AF</item>
    </style>





</resources>
