<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="@dimen/padding_small">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.02"/>

    <FrameLayout
        android:id="@+id/panelRequests"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_requests_panel"
        android:padding="@dimen/padding_normal"
        app:layout_constraintTop_toTopOf="@id/gTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/friend_requests_title"
                android:textColor="#EDE9FE"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_small"
                android:letterSpacing="@dimen/letter_spacing_small"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRequests"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:paddingTop="@dimen/spacing_normal"
                android:paddingBottom="@dimen/spacing_normal"
                app:layout_constraintTop_toBottomOf="@id/tvPending"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/friend_requests_no_requests"
                android:textColor="#C7C7C7"
                android:textSize="@dimen/text_size_normal"
                android:gravity="center"
                android:padding="@dimen/padding_small"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="@id/rvRequests"
                app:layout_constraintBottom_toBottomOf="@id/rvRequests"
                app:layout_constraintStart_toStartOf="@id/rvRequests"
                app:layout_constraintEnd_toEndOf="@id/rvRequests"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
