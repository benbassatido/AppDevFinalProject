<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="18dp"
    android:background="@drawable/bg_room_card_outer_glow"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_room_card_inner"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvRoomTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Duo Squad"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextView
            android:id="@+id/tvRoomSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="BUILD • DUO • 1/2"
            android:textColor="#BFC7D5"
            android:textSize="13sp"
            android:letterSpacing="0.06" />

        <TextView
            android:id="@+id/tvRoomDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="No description"
            android:textColor="#A7B0C0"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_btn_outer_glow_primary"
            android:padding="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinRoom"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="VIEW ROOM"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:textColor="@color/white"
                app:cornerRadius="28dp"
                android:background="@drawable/bg_btn_body_primary"
                android:backgroundTint="@null"
                app:backgroundTint="@null"
                android:elevation="0dp"/>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
