<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/createRoomRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCreateTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="CREATE ROOM"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="28sp"
        android:letterSpacing="0.06"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvRoomNameLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Room Name"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="22dp"
        app:layout_constraintTop_toBottomOf="@id/tvCreateTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/boxRoomName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_purple_outline"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvRoomNameLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etRoomTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:hint="Room Name"
            android:textColor="@color/white"
            android:textColorHint="#BDBDBD"
            android:inputType="textCapSentences" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDescLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Description"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/boxRoomName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/boxDescription"
        android:layout_width="0dp"
        android:layout_height="130dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_purple_outline"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/tvDescLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDescription"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:gravity="top"
            android:hint="Description here"
            android:textColor="@color/white"
            android:textColorHint="#BDBDBD"
            android:inputType="textMultiLine" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/boxMic"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_purple_outline"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/boxDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_btn_speak_now"
            app:tint="#C9B3FF"
            android:contentDescription="Mic" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Mic Required"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swMicRequired"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:useMaterialThemeColors="false"
            app:thumbTint="@color/purple_primary"
            app:trackTint="@color/purple_primary_40" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/wrapCreate"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:padding="12dp"
        android:background="@drawable/bg_btn_outer_glow_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCreateRoom"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="CREATE ROOM"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            app:cornerRadius="30dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_btn_body_primary"
            android:elevation="0dp"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
