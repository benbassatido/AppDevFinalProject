<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/roomRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cd_back"
        android:src="@android:drawable/ic_media_previous"
        app:tint="#2C3E50"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvRoomHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/room_header"
        android:textColor="#2C3E50"
        android:fontFamily="sans-serif-medium"
        android:textSize="18sp"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/btnLeave"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLeave"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/btn_leave"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        app:cornerRadius="20dp"
        app:backgroundTint="#D32F2F"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoomInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/room_default_name"
                android:textColor="#2C3E50"
                android:fontFamily="sans-serif-medium"
                android:textSize="20sp"
                tools:text="Squad" />

            <TextView
                android:id="@+id/tvRoomSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/room_default_sub"
                android:textColor="#9CA3AF"
                android:fontFamily="sans-serif"
                android:textSize="12sp"
                android:letterSpacing="0.05"
                tools:text="FORTNITE · BUILD · TRIO" />

            <TextView
                android:id="@+id/tvRoomDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/room_default_desc"
                android:textColor="#C0C0C0"
                android:fontFamily="sans-serif"
                android:textSize="13sp"
                tools:text="No description" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPlayersCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/room_players_count_default"
                    android:textColor="#2C3E50"
                    android:fontFamily="sans-serif"
                    android:textSize="14sp"
                    tools:text="Players: 1/3" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivMic"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="#6B7280"
                        android:contentDescription="@string/cd_mic" />

                    <TextView
                        android:id="@+id/tvMicRequired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="@string/room_mic_optional"
                        android:textColor="#8BA7F5"
                        android:fontFamily="sans-serif"
                        android:textSize="12sp"
                        tools:text="Mic: Required" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMembersTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/room_members_title"
        android:textColor="#2C3E50"
        android:fontFamily="sans-serif-medium"
        android:textSize="14sp"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/cardRoomInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMembers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvMembersTitle"
        app:layout_constraintBottom_toTopOf="@id/btnReady"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmptyMembers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/room_no_members"
        android:textColor="#9CA3AF"
        android:gravity="center"
        android:visibility="gone"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="@id/rvMembers"
        app:layout_constraintBottom_toBottomOf="@id/rvMembers"
        app:layout_constraintStart_toStartOf="@id/rvMembers"
        app:layout_constraintEnd_toEndOf="@id/rvMembers"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnReady"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/btn_join_room"
        android:textAllCaps="true"
        android:fontFamily="sans-serif-medium"
        android:textSize="15sp"
        android:letterSpacing="0.05"
        android:textColor="#FFFFFF"
        app:backgroundTint="#8BA7F5"
        app:cornerRadius="28dp"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
