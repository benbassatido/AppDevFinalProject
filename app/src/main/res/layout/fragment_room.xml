<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/roomRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="@dimen/padding_normal">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:background="@android:color/transparent"
        android:contentDescription="@string/cd_back"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvRoomHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/room_header"
        android:textColor="#E6FFFFFF"
        android:textStyle="bold"
        android:textSize="@dimen/text_size_medium"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/btnLeave"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLeave"
        android:layout_width="@dimen/button_width_medium"
        android:layout_height="@dimen/button_height_small"
        android:text="@string/btn_leave"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:visibility="gone"
        app:cornerRadius="@dimen/card_corner_radius_small"
        app:backgroundTint="#D32F2F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRoomInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_normal"
        app:cardCornerRadius="@dimen/card_corner_radius_medium"
        app:cardElevation="@dimen/card_elevation"
        app:strokeWidth="@dimen/card_stroke_width"
        app:strokeColor="#5A33FF"
        app:cardBackgroundColor="#1A0F0F10"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_normal">

            <TextView
                android:id="@+id/tvRoomName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/room_default_name"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_large"
                tools:text="Champion's Squad" />

            <TextView
                android:id="@+id/tvRoomSub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:text="@string/room_default_sub"
                android:textColor="#B9C2CF"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_tiny"
                android:letterSpacing="@dimen/letter_spacing_small"
                tools:text="APEX LEGENDS · BUILD · TRIO" />

            <TextView
                android:id="@+id/tvRoomDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:text="@string/room_default_desc"
                android:textColor="#D6FFFFFF"
                android:textSize="@dimen/text_size_small"
                tools:text="Road to Victory!" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_normal"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvPlayersCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/room_players_count_default"
                    android:textColor="#E6FFFFFF"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_size_small"
                    tools:text="Players: 3/3" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivMic"
                        android:layout_width="@dimen/icon_size_tiny"
                        android:layout_height="@dimen/icon_size_tiny"
                        android:src="@android:drawable/ic_btn_speak_now"
                        app:tint="#B9C2CF"
                        android:contentDescription="@string/cd_mic" />

                    <TextView
                        android:id="@+id/tvMicRequired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_tiny"
                        android:text="@string/room_mic_optional"
                        android:textColor="#B9C2CF"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_size_tiny"
                        tools:text="Mic: Required" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvMembersTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_normal"
        android:text="@string/room_members_title"
        android:textColor="#E6FFFFFF"
        android:textStyle="bold"
        android:textSize="@dimen/text_size_small"
        android:letterSpacing="@dimen/letter_spacing_small"
        app:layout_constraintTop_toBottomOf="@id/cardRoomInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMembers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_small"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvMembersTitle"
        app:layout_constraintBottom_toTopOf="@id/wrapJoin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEmptyMembers"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/room_no_members"
        android:textColor="#B9C2CF"
        android:gravity="center"
        android:visibility="gone"
        android:padding="@dimen/padding_small"
        app:layout_constraintTop_toTopOf="@id/rvMembers"
        app:layout_constraintBottom_toBottomOf="@id/rvMembers"
        app:layout_constraintStart_toStartOf="@id/rvMembers"
        app:layout_constraintEnd_toEndOf="@id/rvMembers"/>

    <FrameLayout
        android:id="@+id/wrapJoin"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height_xxlarge"
        android:background="@drawable/bg_btn_outer_glow_primary"
        android:padding="@dimen/spacing_small"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReady"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/btn_join_room"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="@dimen/letter_spacing_medium"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_body_primary"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/button_corner_radius"
            android:elevation="0dp"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
