<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    tools:context=".ui.home.HomeActivity">

    <!-- TITLE -->
    <TextView
        android:id="@+id/tvHomeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/home_margin"
        android:layout_marginEnd="@dimen/home_margin"
        android:layout_marginTop="@dimen/home_margin_top"
        android:gravity="center"
        android:text="PERSONALIZE SELECT\nEXPERIENCE"
        android:textColor="#E6FFFFFF"
        android:textSize="@dimen/home_txt_size"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- HELLO USER -->
    <TextView
        android:id="@+id/tvHelloUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/home_margin"
        android:text="Hello Player"
        android:textColor="@color/white"
        android:textSize="@dimen/home_txt_size"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvHomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearch"
        style="@style/Widget.App.LoginTextInputLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/home_margin"
        android:layout_marginEnd="@dimen/home_margin"
        android:layout_marginTop="@dimen/home_margin"
        app:boxBackgroundMode="outline"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/sky_blue"
        app:layout_constraintTop_toBottomOf="@id/tvHelloUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="@dimen/txt_height"
            android:hint="SEARCH GAMES..."
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="#7C8896"
            android:paddingStart="10dp"
            android:paddingEnd="14dp"
            android:background="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGames"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/home_margin"
        android:layout_marginEnd="@dimen/home_margin"
        android:layout_marginTop="@dimen/home_margin"
        android:clipToPadding="false"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/tilSearch"
        app:layout_constraintBottom_toTopOf="@id/btnViewFriends"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_game_logo"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnViewFriends"
        android:layout_width="0dp"
        android:layout_height="@dimen/txt_height"
        android:layout_marginStart="@dimen/home_margin"
        android:layout_marginEnd="@dimen/home_margin"
        android:layout_marginTop="@dimen/home_margin"
        android:layout_marginBottom="@dimen/home_margin"
        android:text="VIEW FRIENDS"
        android:textAllCaps="true"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        android:textColor="@color/sky_blue"
        app:cornerRadius="12dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/sky_blue"
        app:backgroundTint="@android:color/transparent"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
