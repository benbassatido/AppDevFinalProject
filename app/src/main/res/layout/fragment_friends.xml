<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/friendsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="20dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SquadApp"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="FRIENDS &amp; SOCIAL"
        android:textStyle="bold"
        android:textSize="35sp"
        android:letterSpacing="0.06"
        android:textColor="@color/white"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/tabsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="10dp"
            android:background="@drawable/bg_btn_outer_glow_primary"
            android:layout_marginEnd="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabFriends"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="FRIENDS LIST"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                app:cornerRadius="30dp"
                app:backgroundTint="@null"
                android:background="@drawable/bg_btn_body_primary"
                android:elevation="0dp" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="10dp"
            android:background="@drawable/bg_btn_outer_glow_primary">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabRequests"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="REQUESTS"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                app:cornerRadius="30dp"
                app:backgroundTint="@null"
                android:background="@drawable/bg_btn_body_primary"
                android:elevation="0dp" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Friends List"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/tabsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearchFriends"
        style="@style/Widget.App.LoginTextInputLayout"
        android:theme="@style/MyTextInputThemeOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:boxBackgroundMode="outline"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/neon_purple"
        app:layout_constraintTop_toBottomOf="@id/tvSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearchFriends"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Search by nickname"
            android:textColor="@color/white"
            android:textColorHint="#9AA3B2"
            android:background="@null" />
    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="0dp"
        android:layout_height="160dp"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tilSearchFriends"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvNoResults"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No users found"
        android:textColor="#9AA3B2"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/rvSearchResults"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFriends"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvNoResults"
        app:layout_constraintBottom_toTopOf="@id/wrapFindTeammates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_friend" />



    <TextView
        android:id="@+id/tvEmptyFriends"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No friends yet"
        android:textColor="#9AA3B2"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvFriends"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/requestsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvNoResults"
        app:layout_constraintBottom_toTopOf="@id/wrapFindTeammates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <FrameLayout
        android:id="@+id/wrapFindTeammates"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="@drawable/bg_btn_outer_glow_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFindTeammates"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="FIND NEW TEAMMATES"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            app:cornerRadius="30dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_btn_body_primary"
            android:elevation="0dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
