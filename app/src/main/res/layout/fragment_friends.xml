<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/friendsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="@dimen/padding_xlarge">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="@dimen/icon_size_medium"
        android:layout_height="@dimen/icon_size_medium"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_media_previous"
        android:contentDescription="@string/cd_back"
        app:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/friends_app_name"
        android:textStyle="bold"
        android:textSize="@dimen/text_size_large"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/friends_title"
        android:textStyle="bold"
        android:textSize="@dimen/text_size_massive"
        android:letterSpacing="@dimen/letter_spacing_small"
        android:textColor="@color/white"
        android:gravity="center"
        android:textAlignment="center"
        android:layout_marginTop="@dimen/spacing_xlarge"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/tabsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xlarge"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="@dimen/spacing_small"
            android:background="@drawable/bg_btn_outer_glow_primary"
            android:layout_marginEnd="@dimen/spacing_medium">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabFriends"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_normal"
                android:text="@string/btn_friends_list"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                app:cornerRadius="@dimen/button_corner_radius"
                app:backgroundTint="@null"
                android:background="@drawable/bg_btn_body_primary"
                android:elevation="0dp" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:padding="@dimen/spacing_small"
            android:background="@drawable/bg_btn_outer_glow_primary">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabRequests"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_normal"
                android:text="@string/btn_requests"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                app:cornerRadius="@dimen/button_corner_radius"
                app:backgroundTint="@null"
                android:background="@drawable/bg_btn_body_primary"
                android:elevation="0dp" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/friends_section_title"
        android:textStyle="bold"
        android:textSize="@dimen/text_size_xlarge"
        android:textColor="@color/white"
        android:layout_marginTop="@dimen/spacing_xlarge"
        app:layout_constraintTop_toBottomOf="@id/tabsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearchFriends"
        style="@style/Widget.App.LoginTextInputLayout"
        android:theme="@style/MyTextInputThemeOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_medium"
        android:visibility="gone"
        app:boxBackgroundMode="outline"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/neon_purple"
        app:layout_constraintTop_toBottomOf="@id/tvSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearchFriends"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_normal"
            android:hint="@string/hint_search_nickname"
            android:textColor="@color/white"
            android:textColorHint="#9AA3B2"
            android:background="@null" />
    </com.google.android.material.textfield.TextInputLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="0dp"
        android:layout_height="@dimen/search_results_height"
        android:layout_marginTop="@dimen/spacing_small"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tilSearchFriends"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvNoResults"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/friends_no_users_found"
        android:textColor="#9AA3B2"
        android:gravity="center"
        android:padding="@dimen/padding_small"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/rvSearchResults"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFriends"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_medium"
        app:layout_constraintTop_toBottomOf="@id/tvNoResults"
        app:layout_constraintBottom_toTopOf="@id/wrapFindTeammates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_friend" />

    <TextView
        android:id="@+id/tvEmptyFriends"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/friends_no_friends"
        android:textColor="#9AA3B2"
        android:gravity="center"
        android:padding="@dimen/padding_small"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvFriends"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/requestsContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvNoResults"
        app:layout_constraintBottom_toTopOf="@id/wrapFindTeammates"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/wrapFindTeammates"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_large"
        android:padding="@dimen/padding_small"
        android:background="@drawable/bg_btn_outer_glow_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFindTeammates"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_xlarge"
            android:text="@string/btn_find_teammates"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            app:cornerRadius="@dimen/button_corner_radius"
            app:backgroundTint="@null"
            android:background="@drawable/bg_btn_body_primary"
            android:elevation="0dp" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
