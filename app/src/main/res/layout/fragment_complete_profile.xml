<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/completeProfileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="@dimen/padding_large">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/complete_profile_title"
        android:textColor="#E6FFFFFF"
        android:textStyle="bold"
        android:textSize="@dimen/text_size_large"
        android:gravity="center"
        android:letterSpacing="@dimen/letter_spacing_small"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_normal"
        app:cardCornerRadius="@dimen/spacing_huge"
        app:cardElevation="0dp"
        app:strokeWidth="@dimen/card_stroke_width_thin"
        app:strokeColor="#7A3AED"
        app:cardBackgroundColor="#1A0F0F10"
        app:layout_constraintTop_toBottomOf="@id/tvHeader"
        app:layout_constraintBottom_toTopOf="@id/wrapSave"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_username"
                android:textColor="#E6FFFFFF"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_normal"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_purple_outline"
                android:padding="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etUsername"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="@string/hint_enter_username"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#B9C2CF"
                    android:inputType="text"
                    android:maxLines="1"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_large"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_nickname"
                android:textColor="#E6FFFFFF"
                android:textStyle="bold"
                android:textSize="@dimen/text_size_normal"
                android:layout_marginBottom="8dp"/>

            <!-- Nickname input box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_purple_outline"
                android:padding="@dimen/padding_small">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNickname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="@string/hint_enter_nickname"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#B9C2CF"
                    android:inputType="textCapWords"
                    android:maxLines="1"/>
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/wrapSave"
        android:layout_width="0dp"
        android:layout_height="@dimen/button_height_xxlarge"
        android:background="@drawable/bg_btn_outer_glow_primary"
        android:padding="@dimen/spacing_small"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/btn_save_profile"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="@dimen/letter_spacing_medium"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_body_primary"
            android:backgroundTint="@null"
            app:backgroundTint="@null"
            app:cornerRadius="@dimen/button_corner_radius"
            android:elevation="0dp"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
