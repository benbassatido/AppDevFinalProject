<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="20dp">

    <!-- ===== TITLE ===== -->
    <TextView
        android:id="@+id/tvHomeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="PERSONALIZE SELECT\nEXPERIENCE"
        android:textColor="#EFFFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:layout_marginTop="26dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- HELLO -->
    <TextView
        android:id="@+id/tvHelloUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Hello Player"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="22sp"
        app:layout_constraintTop_toBottomOf="@id/tvHomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SEARCH (purple outline like the mock) -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearch"
        style="@style/Widget.App.LoginTextInputLayout"
        android:theme="@style/MyTextInputThemeOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        app:boxBackgroundMode="outline"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="@color/neon_purple"
        app:layout_constraintTop_toBottomOf="@id/tvHelloUser"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="SEARCH GAMES..."
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="#9AA3B2"
            android:background="@null"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- GAMES GRID -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGames"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/tilSearch"
        app:layout_constraintBottom_toTopOf="@id/wrapViewFriends"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_game_logo"/>

    <!-- VIEW FRIENDS (same glow style as Login primary) -->
    <FrameLayout
        android:id="@+id/wrapViewFriends"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:padding="12dp"
        android:background="@drawable/bg_btn_outer_glow_primary"
        app:layout_constraintTop_toBottomOf="@id/rvGames"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewFriends"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="VIEW FRIENDS"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            app:cornerRadius="30dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_btn_body_primary"
            android:elevation="0dp"/>
    </FrameLayout>

    <!-- LOG OUT (red glow like mock) -->
    <FrameLayout
        android:id="@+id/wrapLogout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="18dp"
        android:padding="12dp"
        android:background="@drawable/bg_btn_outer_glow_red"
        app:layout_constraintTop_toBottomOf="@id/wrapViewFriends"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="LOG OUT"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:includeFontPadding="false"
            app:cornerRadius="30dp"
            app:backgroundTint="@null"
            android:background="@drawable/bg_btn_body_red"
            android:elevation="0dp"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
