<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/gameVariantRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="18dp">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:src="@android:drawable/ic_media_previous"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- GAME CARD (border + glow style like your mockup) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardGame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="72dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="2dp"
        app:strokeColor="@color/neon_purple"
        app:cardBackgroundColor="#0F1116"
        android:foreground="?attr/selectableItemBackground"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/optionsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="1:1.15">

        <ImageView
            android:id="@+id/ivGameLogo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@string/app_name"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- OPTIONS ROW -->
    <LinearLayout
        android:id="@+id/optionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/cardGame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BUILD -->
        <FrameLayout
            android:id="@+id/wrapBuild"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_outer_glow_primary"
            android:padding="10dp"
            android:layout_marginEnd="10dp">

            <Button
                android:id="@+id/btnBuild"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="BUILD"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                android:background="@drawable/bg_btn_body_primary"/>
        </FrameLayout>

        <!-- NO BUILD -->
        <FrameLayout
            android:id="@+id/wrapNoBuild"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_outer_glow_primary"
            android:padding="10dp"
            android:layout_marginStart="10dp">

            <Button
                android:id="@+id/btnNoBuild"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="NO BUILD"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:includeFontPadding="false"
                android:background="@drawable/bg_btn_body_primary"/>
        </FrameLayout>

    </LinearLayout>

    <!-- SUBTITLE -->
    <TextView
        android:id="@+id/tvSelectMode"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="SELECT A PLAY STYLE"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="18dp"
        app:layout_constraintTop_toBottomOf="@id/optionsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
